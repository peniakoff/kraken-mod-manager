{
  "name": "@kraken/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json && esbuild src/server.ts --bundle --platform=node --format=cjs --outfile=dist/server.cjs && node scripts/copy-frontend.mjs",
    "lint": "oxlint --deny-warnings src test",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "start": "node dist/server.cjs"
  },
  "dependencies": {
    "@kraken/contracts": "workspace:*",
    "@kraken/core": "workspace:*",
    "express": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "esbuild": "^0.28.0",
    "supertest": "^7.0.0",
    "tsx": "^4.0.0",
    "vitest": "^4.0.0"
  }
}
